personal:
  me:
    firstName: op://Personal/Me/first name
    lastName: op://Personal/Me/last name
    occupation: op://Personal/Me/occupation
    preferredName: op://Personal/Me/preferred name
    contact:
      emailAddress: op://Personal/Me/Contact/email
      gitEmail: op://Personal/Me/Contact/git email
      pastEmails: op://Personal/Me/Contact/past emails
      username: op://Personal/Me/Contact/username
      website: op://Personal/Me/contact/website
    home:
      cell: op://Personal/Me/Home/cell
      address: op://Personal/Me/Home/Address
    email:
      smtp:
        port: "op://Personal/Artero.dev Email/SMTP/port"
        security: op://Personal/Artero.dev Email/SMTP/security
        server: op://Personal/Artero.dev Email/SMTP/server
        user: op://Personal/Artero.dev Email/SMTP/username
    tokens:
      breachDirectory: op://Personal/Breach Directory API/credential
      cachix: op://Personal/Cachix wwmoraes RW/credential
      emailRep: op://Personal/EmailRep API/credential
      github: op://Development/GitHub CLI/token
      githubOAuth: op://Development/GitHub CLI/oauth token
      hunterIO: op://Personal/Hunter.io API/credential
      intelX: op://Personal/IntelX API/credential
  pgp:
    fingerprint: op://Personal/PGP/fingerprint
    identity: "op://Personal/PGP/identity"
    url: op://Personal/PGP/url
home:
  wirelessRouter:
    fqdn: op://Home/Wireless Router/FQDN
    baseStationName: op://Home/Wireless Router/base station name
    server: op://Home/Wireless Router/server
    MAC:
      wireless: op://Home/Wireless Router/MAC/wireless
work:
  email: op://Work - AAB/Microsoft/username
  pcs:
    domain: op://Work - AAB/PCS NextGen/domain
  azureDevOps:
    organization: op://Work - AAB/Azure DevOps/website
    project: op://Work - AAB/Azure DevOps/project
  launcher:
    username: op://Work - AAB/Launcher/username
    website: op://Work - AAB/Launcher/website
  nexus:
    proxies:
      python:
        index: op://Work - AAB/Nexus RM/pypi
        indexUrl: op://Work - AAB/Nexus RM/pip-simple
      golang:
        goproxy: op://Work - AAB/Nexus RM/goproxy
        gosumdb: op://Work - AAB/Nexus RM/gosumdb
      node:
        registry: op://Work - AAB/Nexus RM/npm
